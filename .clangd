If:
  PathMatch: deps/lua-termkey/.*
CompileFlags:
  Add: [-std=c99, -Wno-unused-parameter]
  Remove: [-std=c89]
---
If:
  PathMatch: '.*\.h'
CompileFlags:
  Add: [-x, c]
---
CompileFlags:
  Add:
    - "-pedantic"
    - "-std=c89"
    - "-I."
    - "-I.."
    - "-Itests"
    - "-DPT_STATIC_API"
    - "-Wno-variadic-macros"
  Remove:
    - "-Werror"
